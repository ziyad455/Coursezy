    "# ============================================================================\n",
    "# SECTION 5: LOAD BASE MODEL WITH QUANTIZATION\n",
    "# ============================================================================\n",
    "\n",
    "print(\"\\n[4/8] Loading base model with 4-bit quantization...\")\n",
