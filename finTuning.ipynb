    "# ============================================================================\n",
    "# SECTION 7: LOAD AND FORMAT DATASET\n",
    "# ============================================================================\n",
    "print(\"\\n[6/8] Loading dataset from local file...\")\n",
    "\n",
    "# Load your local JSONL dataset\n",
    "dataset = load_dataset(\n",
    "    \"json\",  # Specify the file format\n",
