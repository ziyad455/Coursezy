    "# ============================================================================\n",
    "# SECTION 1: CONFIGURATION\n",
    "# ============================================================================\n",
    "\n",
    "# Hugging Face Configuration\n",
    "HF_TOKEN = \"\"  # Replace with your actual token\n",
